# KOBIL Identity (same values the profile-app uses)
KOBIL_IDP_ISSUER=https://idp.<tenant>.kobil.com/auth/realms/<realm>
KOBIL_SERVICE_CLIENT_ID=
KOBIL_SERVICE_CLIENT_SECRET=
# Optional: override the users API base (defaults to {issuer}/v3_user)
# KOBIL_IDP_USERS_API=

# ── Safety ──────────────────────────────────────────────────────────────────
# Read-only by default. Set to 0 ONLY when you intend to allow writes.
MCP_READONLY=1
# Optional comma-separated allowlist of emails/UUIDs that writes may target.
# Leave empty to allow all (not recommended in shared setups).
# MCP_ALLOWED_USERS=
