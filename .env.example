# KOBIL Identity (Keycloak realm)
# Issuer URL — usually https://idp.<tenant>.kobil.com/auth/realms/<realm>
KOBIL_IDP_ISSUER=
KOBIL_REALM=
KOBIL_TENANT=

# OIDC clients (created in KOBIL Identity by an admin)
# profile-miniapp client = Authorization Code + PKCE
KOBIL_MINIAPP_CLIENT_ID=
KOBIL_MINIAPP_CLIENT_SECRET=

# profile-admin client = Authorization Code + PKCE (separate audience for /admin/*)
# Optional — if unset, /admin/* will refuse to authenticate.
KOBIL_ADMIN_CLIENT_ID=
KOBIL_ADMIN_CLIENT_SECRET=
# Realm role the admin must have to access /admin/*. Default: profile_admin.
KOBIL_ADMIN_ROLE=profile_admin

# profile-service client = client_credentials (server-to-server calls to KOBIL IDP API)
# Required for IDP prefill (getUserInfo) + sync-back (updateProfileUser).
# If unset, the IDP-prefill UI will show a friendly notice instead of failing.
KOBIL_SERVICE_CLIENT_ID=
KOBIL_SERVICE_CLIENT_SECRET=
# Optional override for the IDP users API base. Defaults to
# `${KOBIL_IDP_ISSUER}/v3_user` — KOBIL's custom Users API keyed by email,
# e.g. https://idp.<tenant>.kobil.com/auth/realms/<realm>/v3_user/<email>
KOBIL_IDP_USERS_API=

# Email + phone changes are delegated to KOBIL Identity via the kc_action
# flow (UPDATE_EMAIL, UPDATE_PHONE_NUMBER). Configure the corresponding
# authenticators in the realm to control how the user proves ownership
# (email verification link, SMS-OTP, etc.). No env vars needed here.

# Session signing key for the jose-signed HTTP-only cookie.
# Generate with: openssl rand -base64 48
AUTH_SECRET=

# Public base URL of this app (no trailing slash). Must match a Valid Redirect URI in KOBIL.
APP_BASE_URL=http://localhost:3000

# Postgres (Neon). Auto-injected by the Vercel-Neon integration with the
# configured prefix (PROFILE_). The app uses a single URL for both runtime
# and migrations; PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 (set in
# vercel-build) keeps `prisma migrate deploy` happy against pgbouncer.
PROFILE_URL=                   # pooled URL — used for runtime + migrations

# Optional consent notice version. Bumped whenever the privacy notice copy changes.
PRIVACY_NOTICE_VERSION=2026-05-14

# Embedded-mode flag (future). Leave unset for standalone OIDC login.
# When set to "1", the miniapp expects a host-injected access token cookie and
# disables its own OIDC routes.
PROFILE_EMBED_MODE=
